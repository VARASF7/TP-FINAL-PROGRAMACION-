{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build",
            "command": "cl.exe",
            "args": [
                "\"${workspaceFolder}\\src\\*.cpp\"",
                "/nologo",
                "/EHsc",
                "/Fe\"${workspaceFolder}\\out\\pong.exe\"",
                "/I\"${workspaceFolder}\\libs\\SDL2\\include\"",
                "/I\"${workspaceFolder}\\src\\include\"",
                "/I\"${workspaceFolder}\\libs\\SDL2_image\\include\"",
                "/I\"${workspaceFolder}\\libs\\SDL2_ttf\\include\"",
                "/I\"${workspaceFolder}\\libs\\SDL2_mixer\\include\"",
                "/link",
                "/LIBPATH:\"${workspaceFolder}\\libs\\SDL2\\lib\\x64\"",
                "/LIBPATH:\"${workspaceFolder}\\libs\\SDL2_ttf\\lib\\x64\"",
                "/LIBPATH:\"${workspaceFolder}\\libs\\SDL2_image\\lib\\x64\"",
                "/LIBPATH:\"${workspaceFolder}\\libs\\SDL2_mixer\\lib\\x64\"",
                "SDL2.lib",
                "SDL2main.lib",
                "SDL2_image.lib",
                "SDL2_ttf.lib",
                "SDL2_mixer.lib"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger.",
            "dependsOn":["copy SDL", "copy SDL_image", "copy SDL_ttf", "copy SDL_mixer", "copy assets"]
        },
        {
            "type": "process",
            "label": "copy SDL",
            "command": "xcopy",
            "args": [
                "\"${workspaceFolder}\\libs\\SDL2\\lib\\x64\\*.dll\"",
                "\"${workspaceFolder}\\out\\\"",
                "/Y"
            ],
            "promptOnClose": false
        },
        {
            "type": "process",
            "label": "copy SDL_image",
            "command": "xcopy",
            "args": [
                "\"${workspaceFolder}\\libs\\SDL2_image\\lib\\x64\\*.dll\"",
                "\"${workspaceFolder}\\out\\\"",
                "/Y",
            ],
            "promptOnClose": false
        },
        {
            "type": "process",
            "label": "copy SDL_ttf",
            "command": "xcopy",
            "args": [
                "\"${workspaceFolder}\\libs\\SDL2_ttf\\lib\\x64\\*.dll",
                "\"${workspaceFolder}\\out\\\"",
                "/Y"
            ],
            "promptOnClose": false
        },
        {
            "type": "process",
            "label": "copy SDL_mixer",
            "command": "xcopy",
            "args": [
                "\"${workspaceFolder}\\libs\\SDL2_mixer\\lib\\x64\\*.dll\"",
                "\"${workspaceFolder}\\out\\\"",
                "/Y"
            ],
            "promptOnClose": false
        },
        {
            "type": "process",
            "label": "copy assets",
            "command": "xcopy",
            "args": [
                "\"${workspaceFolder}\\assets\"",
                "\"${workspaceFolder}\\out\"",
                "/Y",
                "/E",
                "/C",
                "/I",
            ],
            "promptOnClose": false
        },
    ],
    "version": "2.0.0"
}